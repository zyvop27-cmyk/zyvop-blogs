# Postgres connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ratelimit_demo

# Redis — backs both the account-lockout counters and (optionally) the
# IP throttle store in a multi-instance deployment
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRATION_TIME=15m

# --- Account lockout (brute-force protection) ---
# Failures are counted per email, independent of which IP they came from.
# LOGIN_LOCKOUT_WINDOW_SECONDS and LOGIN_LOCKOUT_DURATION_SECONDS default
# to the SAME value on purpose: once the lock expires, the failure count
# has also expired, so the account gets a genuine fresh start rather than
# being one more failed attempt away from an immediate re-lock. See the
# README for what happens if you set these to different values.
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_DURATION_SECONDS=900

PORT=3000
